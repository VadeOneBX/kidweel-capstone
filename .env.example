# Market-data credentials only (read-only option chain / greeks staging).
# Do not commit .env — local secrets only. Never print or log secret values.
# Placeholders only in this file — no real API keys.
# This repo does not submit orders from the greeks layer.
#
# Copy to .env and fill in (or export in your shell):
#   cp .env.example .env
#
# Alternative names also supported by the greeks layer:
#   APCA_API_KEY_ID=
#   APCA_API_SECRET_KEY=

ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Paper trading transport only (MCP-C12A). Not used for read-only greeks/chain fetch.
# ALPACA_PAPER_BASE_URL must be exactly https://paper-api.alpaca.markets
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_SECRET_KEY=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# Kidweel local/mobile runtime
QOPS_RUNTIME_MODE=local
QOPS_PAPER_ONLY=true
QOPS_API_PORT=8000
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Mobile notification posture
QOPS_MOBILE_NOTIFY_ENABLED=false
QOPS_MOBILE_NOTIFY_CHANNEL=local

# Tailscale is optional and must not be required for local tests.
TAILSCALE_HOSTNAME=
